<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Sponsorship Hub - Sanity Suite">

    <listeners>
        <listener class-name="com.sponsorship.listeners.ExtentTestListener"/>
    </listeners>

    <test name="Sanity Tests">
        <groups>
            <run>
                <include name="sanity"/>
            </run>
        </groups>
        <packages>
            <package name="com.sponsorship.tests.*"/>
        </packages>
    </test>

</suite>
